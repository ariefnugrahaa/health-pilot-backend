  @@index([bloodTestId])
  @@map("blood_test_interpretations")
}

// ============================================
// ANALYTICS LAYER (ANONYMIZED DATA)
// ============================================
// These tables store anonymized, non-identifiable copies of user data
// for aggregate analytics, provider benchmarking, and research purposes.
// Data is written at intake/bloodtest creation time to ensure no data is lost.

/// Anonymized health intake data for analytics (non-PHI)
model AnalyticsHealthIntake {
  id                    String    @id @default(uuid()) @db.Uuid
  intakeId              String    @unique @map("intake_id") @db.Uuid // Reference only, no FK to prevent identity correlation
  
  // Demographic buckets (not exact values)
  ageBucket             String?   @map("age_bucket") // e.g., "18-24", "25-34", "35-44"
  gender                String?   // anonymized gender
  region                String?   // country or region code
  
  // Health profile flags (non-identifying)
  primaryGoals          String[]  @map("primary_goals")
  symptomCategories     String[]  @map("symptom_categories") // e.g., ["fatigue", "weight"]
  hasChronicConditions  Boolean?  @map("has_chronic_conditions")
  takingMedications     Boolean?  @map("taking_medications")
  
  // Lifestyle buckets
  exerciseLevel         String?   @map("exercise_level") // sedentary, moderate, active
  stressLevel           String?   @map("stress_level") // low, medium, high
  sleepQuality          String?   @map("sleep_quality") // poor, fair, good
  dietType              String?   @map("diet_type") // omnivore, vegetarian, vegan, etc.
  
  // Preference flags
  riskTolerance         String?   @map("risk_tolerance") // low, medium, high
  budgetSensitivity     String?   @map("budget_sensitivity") // low, medium, high
  preferSubscription    Boolean?  @map("prefer_subscription")
  
  // Timestamps
  intakeCompletedAt     DateTime? @map("intake_completed_at")
  createdAt             DateTime  @default(now()) @map("created_at")

  @@index([ageBucket])
  @@index([gender])
  @@index([region])
  @@index([primaryGoals])
  @@index([createdAt])
  @@map("analytics_health_intakes")
}

/// Anonymized blood test data for analytics (non-PHI)
model AnalyticsBloodTest {
  id                    String    @id @default(uuid()) @db.Uuid
  bloodTestId           String    @unique @map("blood_test_id") @db.Uuid // Reference only
  
  // Context
  panelType             String    @map("panel_type")
  labPartnerCode        String?   @map("lab_partner_code")
  region                String?
  
  // Aggregated biomarker flags (not values)
  biomarkerFlags        Json      @map("biomarker_flags") @db.JsonB
  // Structure: { "TESTOSTERONE": "low", "VITAMIN_D": "normal", "TSH": "high" }
  
  abnormalCount         Int       @map("abnormal_count")
  totalBiomarkers       Int       @map("total_biomarkers")
  
  // Demographics for cross-referencing
  ageBucket             String?   @map("age_bucket")
  gender                String?
  
  // Timestamps
  resultsReceivedAt     DateTime? @map("results_received_at")
  createdAt             DateTime  @default(now()) @map("created_at")

  @@index([panelType])
  @@index([labPartnerCode])
  @@index([ageBucket])
  @@index([gender])
  @@index([createdAt])
  @@map("analytics_blood_tests")
}

/// Anonymized treatment outcome data for provider benchmarking
model AnalyticsTreatmentOutcome {
  id                    String    @id @default(uuid()) @db.Uuid
  handoffId             String    @unique @map("handoff_id") @db.Uuid // Reference only
  
  // Provider & Treatment (not user-identifiable)
  providerId            String    @map("provider_id") @db.Uuid
  treatmentId           String    @map("treatment_id") @db.Uuid
  treatmentCategory     String    @map("treatment_category")
  
  // Outcome tracking
  handoffStatus         String    @map("handoff_status")
  convertedToTreatment  Boolean   @map("converted_to_treatment")
  subscriptionActive    Boolean?  @map("subscription_active")
  
  // Time metrics
  daysToConversion      Int?      @map("days_to_conversion")
  subscriptionMonths    Int?      @map("subscription_months")
  
  // Revenue (anonymized amounts not tied to user)
  revenueGenerated      Decimal?  @map("revenue_generated") @db.Decimal(10, 2)
  commissionGenerated   Decimal?  @map("commission_generated") @db.Decimal(10, 2)
  
  // Demographics for segmentation
  ageBucket             String?   @map("age_bucket")
  gender                String?
  region                String?
  
  // Timestamps
  handoffInitiatedAt    DateTime  @map("handoff_initiated_at")
  lastUpdatedAt         DateTime  @map("last_updated_at")
  createdAt             DateTime  @default(now()) @map("created_at")

  @@index([providerId])
  @@index([treatmentId])
  @@index([treatmentCategory])
  @@index([handoffStatus])
  @@index([convertedToTreatment])
  @@index([createdAt])
  @@map("analytics_treatment_outcomes")
}

/// Aggregate provider performance metrics (daily snapshots)
model ProviderAnalyticsSnapshot {
  id                    String    @id @default(uuid()) @db.Uuid
  providerId            String    @map("provider_id") @db.Uuid
  snapshotDate          DateTime  @map("snapshot_date") @db.Date
  
  // Conversion metrics
  totalHandoffs         Int       @map("total_handoffs")
  convertedHandoffs     Int       @map("converted_handoffs")
  conversionRate        Decimal   @map("conversion_rate") @db.Decimal(5, 4)
  
  // Retention metrics
  activeSubscriptions   Int       @map("active_subscriptions")
  churnedSubscriptions  Int       @map("churned_subscriptions")
  retentionRate         Decimal?  @map("retention_rate") @db.Decimal(5, 4)
  
  // Revenue metrics
  totalRevenue          Decimal   @map("total_revenue") @db.Decimal(12, 2)
  totalCommission       Decimal   @map("total_commission") @db.Decimal(12, 2)
  avgRevenuePerHandoff  Decimal?  @map("avg_revenue_per_handoff") @db.Decimal(10, 2)
  
  // Comparison to market (percentile ranks)
  conversionRank        Int?      @map("conversion_rank") // 1-100 percentile
  retentionRank         Int?      @map("retention_rank")
  revenueRank           Int?      @map("revenue_rank")
  
  createdAt             DateTime  @default(now()) @map("created_at")

  @@unique([providerId, snapshotDate])
  @@index([providerId])
  @@index([snapshotDate])
  @@map("provider_analytics_snapshots")
}

// ============================================
// SUPPLEMENTS (Non-Provider Treatments)
// ============================================

/// Category for supplements
enum SupplementCategory {
  VITAMIN
  MINERAL
  HERB
  AMINO_ACID
  PROBIOTIC
  OMEGA
  ENZYME
  ADAPTOGEN
  LIFESTYLE_CHANGE
  OTHER
}

/// Supplements - generic products not tied to a specific provider
/// Can be recommended without provider involvement
model Supplement {
  id                String              @id @default(uuid()) @db.Uuid
  name              String
  slug              String              @unique
  description       String?             @db.Text
  category          SupplementCategory
  
  // Evidence and safety
  evidenceLevel     String?             @map("evidence_level") // strong, moderate, weak, anecdotal
  primaryBenefits   String[]            @map("primary_benefits")
  
  // Dosage info
  recommendedDosage String?             @map("recommended_dosage")
  dosageUnit        String?             @map("dosage_unit")
  frequency         String?             // daily, twice_daily, weekly, etc.
  
  // Target health areas
  targetSymptoms    String[]            @map("target_symptoms")
  targetGoals       String[]            @map("target_goals")
  targetBiomarkers  String[]            @map("target_biomarkers") // biomarker codes this helps with
  
  // Eligibility/Safety
  minAge            Int?                @map("min_age")
  maxAge            Int?                @map("max_age")
  allowedGenders    Gender[]            @map("allowed_genders")
  contraindications String[]            // e.g., ["pregnancy", "blood_thinners"]
  interactions      String[]            // drug/supplement interactions
  sideEffects       String[]            @map("side_effects")
  safetyNotes       String?             @map("safety_notes") @db.Text
  
  // Affiliate/Purchase info
  affiliateLinks    Json?               @map("affiliate_links") // {amazon: url, iherb: url, etc.}
  averagePrice      Decimal?            @map("average_price") @db.Decimal(10, 2)
  currency          String              @default("GBP")
  
  isActive          Boolean             @default(true) @map("is_active")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  // Relations
  supplementMatches SupplementMatch[]

  @@index([category])
  @@index([slug])
  @@index([isActive])
  @@index([targetSymptoms])
  @@index([targetGoals])
  @@map("supplements")
}

/// Match between recommendation and supplement
model SupplementMatch {
  id               String          @id @default(uuid()) @db.Uuid
  recommendationId String          @map("recommendation_id") @db.Uuid
  supplementId     String          @map("supplement_id") @db.Uuid
  matchScore       Int             @map("match_score") // 0-100
  matchReason      String?         @map("match_reason") @db.Text

  // Priority within recommendation (1 = highest)
  priority         Int             @default(1)

  // AI-generated personalization
  personalizedDosage String?       @map("personalized_dosage")
  expectedBenefit    String?       @map("expected_benefit") @db.Text

  // Tracking
  status           String          @default("SUGGESTED") // SUGGESTED, VIEWED, PURCHASED, DISMISSED
  viewedAt         DateTime?       @map("viewed_at")
  purchasedAt      DateTime?       @map("purchased_at")
  affiliateClicked Boolean         @default(false) @map("affiliate_clicked")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  // Relations
  recommendation   Recommendation  @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  supplement       Supplement      @relation(fields: [supplementId], references: [id])

  @@unique([recommendationId, supplementId])
  @@index([recommendationId])
  @@index([supplementId])
  @@index([status])
  @@map("supplement_matches")
}

// ============================================
// FEEDBACK & RATING SYSTEM
// ============================================

enum ProviderRatingCategory {
  OVERALL
  COMMUNICATION
  PROFESSIONALISM
  RESULTS
  VALUE_FOR_MONEY
}

enum TreatmentFeedbackOutcome {
  EXCELLENT
  GOOD
  NEUTRAL
  DISAPPOINTING
  POOR
}

/// Provider ratings from users
model ProviderRating {
  id                String                @id @default(uuid()) @db.Uuid
  userId            String                @map("user_id") @db.Uuid
  providerId        String                @map("provider_id") @db.Uuid
  handoffId         String?               @map("handoff_id") @db.Uuid
  category          ProviderRatingCategory @default(OVERALL)
  rating            Int
  reviewTitle       String?               @map("review_title")
  reviewText        String?               @map("review_text") @db.Text
  wouldRecommend    Boolean?              @map("would_recommend")
  isVerified        Boolean               @default(false) @map("is_verified")
  isPublic          Boolean               @default(true) @map("is_public")
  helpfulCount      Int                   @default(0) @map("helpful_count")
  reportedCount     Int                   @default(0) @map("reported_count")
  moderationStatus  String                @default("APPROVED") @map("moderation_status")
  moderatedAt       DateTime?             @map("moderated_at")
  moderatedBy       String?               @map("moderated_by")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  // Relations
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          Provider              @relation(fields: [providerId], references: [id], onDelete: Cascade)
  handoff           ProviderHandoff?      @relation(fields: [handoffId], references: [id])

  @@index([userId])
  @@index([providerId])
  @@index([handoffId])
  @@index([category])
  @@index([rating])
  @@index([createdAt])
  @@index([moderationStatus, isPublic])
  @@map("provider_ratings")
}

/// Treatment feedback from users
model TreatmentFeedback {
  id                    String                @id @default(uuid()) @db.Uuid
  userId                String                @map("user_id") @db.Uuid
  treatmentId           String                @map("treatment_id") @db.Uuid
  providerId            String                @map("provider_id") @db.Uuid
  handoffId             String?               @map("handoff_id") @db.Uuid
  outcome               TreatmentFeedbackOutcome
  effectivenessRating   Int?                  @map("effectiveness_rating")
  sideEffectsRating     Int?                  @map("side_effects_rating")
  easeOfUseRating       Int?                  @map("ease_of_use_rating")
  feedbackText          String?               @map("feedback_text") @db.Text
  symptomsImproved      String[]              @map("symptoms_improved")
  symptomsUnchanged     String[]              @map("symptoms_unchanged")
  symptomsWorsened      String[]              @map("symptoms_worsened")
  sideEffectsExperienced String[]             @map("side_effects_experienced")
  durationWeeks         Int?                  @map("duration_weeks")
  wouldContinue         Boolean?              @map("would_continue")
  wouldRecommend        Boolean?              @map("would_recommend")
  isAnonymous           Boolean               @default(true) @map("is_anonymous")
  isPublic              Boolean               @default(false) @map("is_public")
  moderationStatus      String                @default("PENDING") @map("moderation_status")
  moderatedAt           DateTime?             @map("moderated_at")
  moderatedBy           String?               @map("moderated_by")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  // Relations
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  treatment             Treatment             @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  provider              Provider              @relation(fields: [providerId], references: [id], onDelete: Cascade)
  handoff               ProviderHandoff?      @relation(fields: [handoffId], references: [id])

  @@index([userId])
  @@index([treatmentId])
  @@index([providerId])
  @@index([handoffId])
  @@index([outcome])
  @@index([createdAt])
  @@index([moderationStatus, isPublic])
  @@map("treatment_feedback")
}

/// Provider rating summary (materialized view equivalent)
model ProviderRatingSummary {
  id                    String    @id @default(uuid()) @db.Uuid
  providerId            String    @unique @map("provider_id") @db.Uuid
  overallRating         Decimal   @default(0) @map("overall_rating") @db.Decimal(3, 2)
  communicationRating   Decimal?  @map("communication_rating") @db.Decimal(3, 2)
  professionalismRating Decimal?  @map("professionalism_rating") @db.Decimal(3, 2)
  resultsRating         Decimal?  @map("results_rating") @db.Decimal(3, 2)
  valueRating           Decimal?  @map("value_rating") @db.Decimal(3, 2)
  totalReviews          Int       @default(0) @map("total_reviews")
  fiveStarCount         Int       @default(0) @map("five_star_count")
  fourStarCount         Int       @default(0) @map("four_star_count")
  threeStarCount        Int       @default(0) @map("three_star_count")
  twoStarCount          Int       @default(0) @map("two_star_count")
  oneStarCount          Int       @default(0) @map("one_star_count")
  recommendationRate    Decimal?  @map("recommendation_rate") @db.Decimal(5, 4)
  lastCalculatedAt      DateTime  @default(now()) @map("last_calculated_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relations
  provider              Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_rating_summaries")
}

/// Treatment feedback summary (materialized view equivalent)
model TreatmentFeedbackSummary {
  id                  String    @id @default(uuid()) @db.Uuid
  treatmentId         String    @unique @map("treatment_id") @db.Uuid
  providerId          String    @map("provider_id") @db.Uuid
  avgEffectiveness    Decimal?  @map("avg_effectiveness") @db.Decimal(3, 2)
  avgSideEffects      Decimal?  @map("avg_side_effects") @db.Decimal(3, 2)
  avgEaseOfUse        Decimal?  @map("avg_ease_of_use") @db.Decimal(3, 2)
  totalFeedback       Int       @default(0) @map("total_feedback")
  excellentCount      Int       @default(0) @map("excellent_count")
  goodCount           Int       @default(0) @map("good_count")
  neutralCount        Int       @default(0) @map("neutral_count")
  disappointingCount  Int       @default(0) @map("disappointing_count")
  poorCount           Int       @default(0) @map("poor_count")
  continuationRate    Decimal?  @map("continuation_rate") @db.Decimal(5, 4)
  recommendationRate  Decimal?  @map("recommendation_rate") @db.Decimal(5, 4)
  commonImprovements  String[]  @map("common_improvements")
  commonSideEffects   String[]  @map("common_side_effects")
  lastCalculatedAt    DateTime  @default(now()) @map("last_calculated_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  treatment           Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  provider            Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([treatmentId])
  @@map("treatment_feedback_summaries")
}

