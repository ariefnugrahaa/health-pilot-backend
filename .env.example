# ============================================
# HealthPilot Backend Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_USER=healthpilot
POSTGRES_PASSWORD=healthpilot_secret
POSTGRES_DB=healthpilot
POSTGRES_PORT=5432
DATABASE_URL=postgresql://healthpilot:healthpilot_secret@localhost:5432/healthpilot?schema=public

# ============================================
# Redis
# ============================================
REDIS_PASSWORD=healthpilot_redis_secret
REDIS_PORT=6379
REDIS_URL=redis://:healthpilot_redis_secret@localhost:6379

# ============================================
# Authentication (JWT)
# ============================================
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Encryption (PHI Data)
# ============================================
# Generate a 32-character key: openssl rand -hex 16
ENCRYPTION_KEY=your-32-character-encryption-key!
ENCRYPTION_ALGORITHM=aes-256-gcm

# ============================================
# OpenAI
# ============================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TIMEOUT=60000

# ============================================
# Cloudflare
# ============================================
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=combined

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

# ============================================
# Development Tools (Optional)
# ============================================
PGADMIN_EMAIL=admin@healthpilot.com
PGADMIN_PASSWORD=admin
